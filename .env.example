# ===================================================
# 吃了吗 (Chileoma) 本地开发环境变量配置模板
# 将此文件复制为 .env 并填写真实值
# ===================================================

# MySQL 数据库连接串
# 格式: mysql://用户名:密码@主机:端口/数据库名
# 本地示例: mysql://root:yourpassword@localhost:3306/chileoma
# Docker 示例: mysql://root:yourpassword@127.0.0.1:3306/chileoma
DATABASE_URL=mysql://root:yourpassword@localhost:3306/chileoma

# JWT 密钥（用于签发 session token，请使用随机32位以上字符串）
# 可用此命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-at-least-32-chars

# Google OAuth 配置
# 在 https://console.cloud.google.com/ 创建 OAuth 2.0 Client ID 后填写
# Authorized redirect URI 填写: http://localhost:3000/api/oauth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 应用访问地址（本地开发为 localhost:3000）
VITE_APP_URL=http://localhost:3000

# ===================================================
# 以下为可选配置
# ===================================================

# 管理员账号的 openId（格式: google:Google用户sub字段值）
# 登录后在后端日志中查看 openId
OWNER_OPEN_ID=google:your-google-sub-id
